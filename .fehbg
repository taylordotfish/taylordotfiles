set -euf

dir="$(dirname "$0")"
image=/etc/alternatives/desktop-theme/wallpaper/contents/images/1920x1080.svg
if [ -f "$dir"/.fehbg.pre.sh ]; then
    . "$dir"/.fehbg.pre.sh
fi

handle_monitor() {
    local clean_name
    case "$monitor_name" in
        *[!A-Za-z0-9_]*) clean_name=$(printf '%s' "$monitor_name" |
            tr - _ | tr -dC A-Za-z0-9_) ;;
        *) clean_name=$monitor_name ;;
    esac
    local monitor_image
    eval "monitor_image=\${image_name_$clean_name-}"

    if [ -z "$monitor_image" ]; then
        case "$monitor_tech" in
            *[!A-Za-z0-9_]*) ;;
            *) eval "monitor_image=\${image_tech_$monitor_tech-}" ;;
        esac
    fi
    if [ -z "$monitor_image" ]; then
        monitor_image=$image
    fi
    local screen="$((monitor_screen))"
    eval "mimage_$screen=\$monitor_image"
}

eval "$(~/scripts/monitor-utils/sh/foreach.sh handle_monitor)"

i=0
set --
while true; do
    eval "mimage=\${mimage_$i-}"
    [ -n "$mimage" ] || break
    set -- "$@" "$mimage"
    i=$((i+1))
done

if [ "$#" -gt 0 ]; then
    exec feh --no-fehbg --bg-fill "$@"
fi
