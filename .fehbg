set -euf

dir=$(dirname -- "$0")

default_get_image() {
    if [ "$monitor_tech" = epaper ]; then
        local dir
        dir=~/.cache/fehbg
        if ! [ -e "$dir"/white.png ]; then
            mkdir -p -- "$dir"
            convert -size 16x16 xc:white "$dir"/white.png
        fi
        image=$dir/white.png
        return
    fi

    local dir=/etc/alternatives/desktop-theme/wallpaper/contents/images
    set +f
    set -f -- "$dir"/*.svg
    local widest_image=
    local max_width=
    local best_image=
    local best_area=
    local f
    for f do
        if ! [ -f "$f" ]; then
            continue
        fi
        local name="${f##*/}"
        name=${name%%.*}
        local width="${name%%x*}"
        local height="${name##*x}"
        case "$width" in
            *[!0-9]*|"") continue ;;
        esac
        case "$height" in
            *[!0-9]*|"") continue ;;
        esac
        if [ -z "$max_width" ] || [ "$width" -gt "$max_width" ]; then
            widest_image=$f
            max_width=$width
        fi
        if [ "$width" -lt "$monitor_width" ]; then
            continue
        fi
        if [ "$height" -lt "$monitor_height" ]; then
            continue
        fi
        local area="$((width * height))"
        if [ -z "$best_area" ] || [ "$area" -lt "$best_area" ]; then
            best_image=$f
            best_area=$area
        fi
    done
    if [ -n "$best_image" ]; then
        image=$best_image
    elif [ -n "$widest_image" ]; then
        image=$widest_image
    fi
}

get_image() {
    :
}

if [ -f "$dir"/.fehbg.pre.sh ]; then
    # `get_image` can be overridden here.
    . "$dir"/.fehbg.pre.sh
fi

handle_monitor() {
    local image
    unset image
    get_image
    [ -n "${image+x}" ] || default_get_image
    if [ -z "${image+x}" ]; then
        local msg=".fehbg: could not find image for screen $monitor_screen"
        msg="$msg (${monitor_width}x${monitor_height})"
        printf >&2 '%s\n' "$msg"
    fi
    local screen="$((monitor_screen))"
    eval "image$screen=\$image"
}

eval "$(~/scripts/monitor-utils/sh/foreach.sh handle_monitor)"

i=0
set --
while true; do
    eval "image=\${image$i-}"
    [ -n "$image" ] || break
    set -- "$@" "$image"
    : $((i += 1))
done

if [ "$#" -gt 0 ]; then
    exec feh --no-fehbg --bg-fill "$@"
fi
