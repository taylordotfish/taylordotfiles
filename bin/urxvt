#!/bin/sh
# Copyright (C) 2023-2026 taylor.fish <contact@taylor.fish>
# License: GNU GPL version 3 or later
set -euf

dir=$(dirname "$0")
path=:$PATH:
case "$path" in
    *:$dir:*) path=${path%%:"$dir":*}:${path#*:"$dir":} ;;
esac
path=${path#:}
path=${path%:}
if ! urxvt=$(PATH=$path command -v urxvt); then
    printf >&2 '%s\n' 'error: missing urxvt'
    exit 1
fi

args=
cmd=
unset -v name title
per_monitor=
state=
i=0

for arg do
    : $((i += 1))
    case "$state" in
        -name)
            name=$arg
            state=
            continue
            ;;
        -title)
            title=$arg
            state=
            continue
            ;;
        -e)
            cmd="$cmd \"\${$i}\""
            if [ -z "${title+x}" ]; then
                title=$(basename "$arg")
            fi
            continue
            ;;
    esac
    case "${arg-}" in
        -name|-title|-e)
            state=$arg
            ;;
        -per-monitor)
            per_monitor=1
            ;;
        *)
            args="$args \"\${$i}\""
            ;;
    esac
done

eval "$(~/scripts/monitor-utils/sh/globals.sh)"
monitor_dpi=$global_monitor_dpi
monitor_tech=$global_monitor_tech
if [ -n "$per_monitor" ]; then
    eval "$(~/scripts/monitor-utils/sh/focused.sh)"
fi

[ -n "$cmd" ] || cmd=$(awk -vFS=: '
    BEGIN {
        uid = ARGV[2]
        ARGC = 2
    }

    $3 == uid {
        print $7
    }
' /etc/passwd "$(id -u)")
: ${cmd:=bash}

colors_sh=~/scripts/set-urxvt-colors.sh
if [ "$monitor_tech" = epaper ]; then
    if command -v monoterm > /dev/null; then
        cmd="monoterm -b $cmd"
    fi
elif [ -z "${URXVT_NO_SET_COLORS-}" ] && [ -x "$colors_sh" ]; then
    cmd="\"\$colors_sh\" $cmd"
fi

fix_sh=~/scripts/fix-urxvt-position.sh
if [ -z "${URXVT_NO_FIX_POSITION-}" ] && [ -x "$fix_sh" ]; then
    cmd="\"\$fix_sh\" $cmd"
fi

if [ -z "${name+x}" ]; then
    name=Rxvt
    if [ "$monitor_tech" = epaper ]; then
        name=$name.epaper
    fi
    if [ "$monitor_dpi" -ne "$global_monitor_dpi" ]; then
        name=$name.${monitor_dpi}dpi
    fi
fi

if [ "$monitor_tech" = epaper ]; then
    export MONOCHROME=1
else
    unset -v MONOCHROME
fi
if [ "$monitor_dpi" -ge 144 ]; then
    export HEAVY_BLOCKS=1
else
    unset -v HEAVY_BLOCKS
fi

: ${title=urxvt}
eval "set -- $args -e $cmd"
exec "$urxvt" -name "$name" -title "$title" "$@"
