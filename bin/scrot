set -euf

dir=$(dirname "$0")
path=:$PATH:
case "$path" in
    *:$dir:*) path=${path%%:"$dir":*}:${path#*:"$dir":} ;;
esac
path=${path#:}
path=${path%:}
if ! scrot=$(PATH=$path command -v scrot); then
    printf >&2 '%s\n' 'error: missing scrot'
    exit 1
fi

IFS='
'
fullwidth=0
fullheight=0
im_args=

handle_monitor() {
    local x="$((monitor_x))"
    local y="$((monitor_y))"
    local width="$((monitor_width))"
    local height="$((monitor_height))"

    local right="$((x + width))"
    local bottom="$((y + height))"
    [ "$right" -le "$fullwidth" ] || fullwidth=$right
    [ "$bottom" -le "$fullheight" ] || fullheight=$bottom

    local p1="$x,$y"
    local p2="$((x + width - 1)),$((y + height - 1))"
    im_args="$im_args -draw 'rectangle $p1 $p2'"
}

eval "$(~/scripts/monitor-utils/sh/foreach.sh handle_monitor)"

exec "$scrot" -e "$(
cat << EOF
set -euf
size=${fullwidth}x${fullheight}
set -- $im_args
EOF
cat << 'EOF'
f=$$(realpath -- '$f')
if [ "$$(identify -format '%%wx%%h' "$$f")" = "$$size" ]; then
    set -- "$$f" "(" -size "$$size" xc:black -fill white "$$@" -alpha off ")"
    convert "$$@" -compose copy-opacity -composite -alpha remove "$$f"
fi
EOF
)" "$@"
