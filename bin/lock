set -euf

screenshot_dir=~/.cache/i3lock-screenshots

run_i3lock_blocking() {
    local picom=
    if pkill -x picom; then
        picom=1
    fi
    i3lock -n "$@"
    if [ -n "$picom" ]; then
        exec picom > /dev/null 2>&1
    fi
}

run_i3lock() {
    run_i3lock_blocking "$@" &
}

any_screenshots=

rm_screenshots() {
    [ -n "$any_screenshots" ] || return 0
    set +f
    set -f -- "$screenshot_dir"/screen_*.png
    rm -f -- "$@"
    any_screenshots=
}

on_exit() {
    local status="$?"
    trap - HUP INT QUIT TERM EXIT
    rm_screenshots
    exit "$status"
}

trap on_exit HUP INT QUIT TERM EXIT

handle_monitor() {
    local screen="$((monitor_screen))"
    local x="$((monitor_x))"
    local y="$((monitor_y))"
    local width="$((monitor_width))"
    local height="$((monitor_height))"
    local endx="$((x + width))"
    local endy="$((y + height))"
    [ "$endx" -le "$maxx" ] || maxx=$endx
    [ "$endy" -le "$maxy" ] || maxy=$endy

    if [ "$monitor_tech" = epaper ]; then
        im_args="$im_args -size '${width}x${height}' xc:white"
    else
        any_screenshots=1
        local path="$screenshot_dir/screen_$screen.png"
        local blur_sigma="$((monitor_dpi * 8 / 96))"
        {
            scrot -oM "$screen" "$path"
            mogrify -colorspace RGB -blur 0x"$blur_sigma" -colorspace sRGB \
                "$path"
        } &
        eval "path_$screen=\$path"
        im_args="$im_args \$path_$screen"
    fi
    im_args="$im_args -geometry '+$x+$y' -composite"
}

if [ -d "$screenshot_dir" ]; then
    maxx=0
    maxy=0
    im_args=
    eval "$(~/scripts/monitor-utils/sh/foreach.sh handle_monitor)"
    eval "set -- $im_args"
    wait
    convert -size "$maxx"x"$maxy" xc:white "$@" "$screenshot_dir"/full.png
    rm_screenshots
    run_i3lock -i "$screenshot_dir"/full.png
    exit
fi

eval "$(~/scripts/monitor-utils/sh/globals.sh)"
if [ "$global_monitor_tech" = epaper ]; then
    run_i3lock -c ffffff
else
    run_i3lock -c 000000
fi
